        {
          "name": "Request_R",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const jsonData = pm.response.json();\r",
                  "\r",
                  "const schema = {\r",
                  "    \"type\": \"object\",\r",
                  "\r",
                  "    \"required\": [\r",
                  "        \"page\",\r",
                  "        \"per_page\",\r",
                  "        \"total\",\r",
                  "        \"total_pages\",\r",
                  "        \"data\",\r",
                  "        \"support\"\r",
                  "    ],\r",
                  "\r",
                  "    \"properties\": {\r",
                  "\r",
                  "        \"page\": {\r",
                  "            \"type\": \"integer\"\r",
                  "        },\r",
                  "\r",
                  "        \"per_page\": {\r",
                  "            \"type\": \"integer\"\r",
                  "        },\r",
                  "\r",
                  "        \"total\": {\r",
                  "            \"type\": \"integer\",\r",
                  "            \"enum\": [12]\r",
                  "        },\r",
                  "\r",
                  "        \"total_pages\": {\r",
                  "            \"type\": \"integer\",\r",
                  "            \"enum\": [2]\r",
                  "        },\r",
                  "\r",
                  "        \"data\": {\r",
                  "            \"type\": \"array\",\r",
                  "            \"minItems\": 1,\r",
                  "            \"maxItems\": 6\r",
                  "        },\r",
                  "\r",
                  "        \"support\": {\r",
                  "            \"type\": \"object\",\r",
                  "\r",
                  "            \"required\": [\r",
                  "                \"url\",\r",
                  "                \"text\"\r",
                  "            ],\r",
                  "\r",
                  "            \"properties\": {\r",
                  "\r",
                  "                \"url\": {\r",
                  "                    \"type\": \"string\"\r",
                  "                },\r",
                  "\r",
                  "                \"text\": {\r",
                  "                    \"type\": \"string\"\r",
                  "                }\r",
                  "            }\r",
                  "        }\r",
                  "    }\r",
                  "};\r",
                  "\r",
                  "pm.test(\"Pagination response schema is valid\", function () {\r",
                  "\r",
                  "    pm.response.to.have.jsonSchema(schema);\r",
                  "\r",
                  "});\r",
                  "\r",
                  "pm.test(\"per_page * total_pages >= total\", function () {\r",
                  "\r",
                  "    pm.expect(\r",
                  "        jsonData.per_page * jsonData.total_pages\r",
                  "    ).to.be.at.least(jsonData.total);\r",
                  "\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{xApiKey}}",
                "type": "text"
              }
            ],
