      "item": [
        {
          "name": "Request_O",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Validate FakeStore response schema\", function () {\r",
                  "\r",
                  "    const schema = {\r",
                  "        \"type\": \"object\",\r",
                  "\r",
                  "        \"required\": [\r",
                  "            \"id\",\r",
                  "            \"title\",\r",
                  "            \"price\",\r",
                  "            \"description\",\r",
                  "            \"category\",\r",
                  "            \"image\",\r",
                  "            \"rating\"\r",
                  "        ],\r",
                  "\r",
                  "        \"properties\": {\r",
                  "\r",
                  "            \"id\": {\r",
                  "                \"type\": \"integer\"\r",
                  "            },\r",
                  "\r",
                  "            \"title\": {\r",
                  "                \"type\": \"string\",\r",
                  "                \"minLength\": 1\r",
                  "            },\r",
                  "\r",
                  "            \"price\": {\r",
                  "                \"type\": \"number\",\r",
                  "                \"exclusiveMinimum\": 0\r",
                  "            },\r",
                  "\r",
                  "            \"description\": {\r",
                  "                \"type\": \"string\"\r",
                  "            },\r",
                  "\r",
                  "            \"category\": {\r",
                  "                \"type\": \"string\"\r",
                  "            },\r",
                  "\r",
                  "            \"image\": {\r",
                  "                \"type\": \"string\",\r",
                  "                \"format\": \"uri\"\r",
                  "            },\r",
                  "\r",
                  "            \"rating\": {\r",
                  "                \"type\": \"object\",\r",
                  "\r",
                  "                \"required\": [\r",
                  "                    \"rate\",\r",
                  "                    \"count\"\r",
                  "                ],\r",
                  "\r",
                  "                \"properties\": {\r",
                  "\r",
                  "                    \"rate\": {\r",
                  "                        \"type\": \"number\",\r",
                  "                        \"minimum\": 0,\r",
                  "                        \"maximum\": 5\r",
                  "                    },\r",
                  "\r",
                  "                    \"count\": {\r",
                  "                        \"type\": \"integer\",\r",
                  "                        \"minimum\": 0\r",
                  "                    }\r",
                  "                }\r",
                  "            }\r",
                  "        }\r",
                  "    };\r",
                  "\r",
                  "    pm.response.to.have.jsonSchema(schema);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "https://fakestoreapi.com/products/1",
              "protocol": "https",
              "host": [
                "fakestoreapi",
                "com"
              ],
              "path": [
                "products",
                "1"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Request_P",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const products = pm.response.json();\r",
                  "\r",
                  "const productSchema = {\r",
                  "    \"type\": \"object\",\r",
                  "\r",
                  "    \"required\": [\r",
                  "        \"id\",\r",
                  "        \"title\",\r",
                  "        \"price\",\r",
                  "        \"description\",\r",
                  "        \"category\",\r",
                  "        \"image\",\r",
                  "        \"rating\"\r",
                  "    ],\r",
                  "\r",
                  "    \"properties\": {\r",
                  "\r",
                  "        \"id\": {\r",
                  "            \"type\": \"integer\"\r",
                  "        },\r",
                  "\r",
                  "        \"title\": {\r",
                  "            \"type\": \"string\",\r",
                  "            \"minLength\": 1\r",
                  "        },\r",
                  "\r",
                  "        \"price\": {\r",
                  "            \"type\": \"number\",\r",
                  "            \"exclusiveMinimum\": 0\r",
                  "        },\r",
                  "\r",
                  "        \"description\": {\r",
                  "            \"type\": \"string\"\r",
                  "        },\r",
                  "\r",
                  "        \"category\": {\r",
                  "            \"type\": \"string\"\r",
                  "        },\r",
                  "\r",
                  "        \"image\": {\r",
                  "            \"type\": \"string\",\r",
                  "            \"format\": \"uri\"\r",
                  "        },\r",
                  "\r",
                  "        \"rating\": {\r",
                  "            \"type\": \"object\",\r",
                  "\r",
                  "            \"required\": [\r",
                  "                \"rate\",\r",
                  "                \"count\"\r",
                  "            ],\r",
                  "\r",
                  "            \"properties\": {\r",
                  "\r",
                  "                \"rate\": {\r",
                  "                    \"type\": \"number\",\r",
                  "                    \"minimum\": 0,\r",
                  "                    \"maximum\": 5\r",
                  "                },\r",
                  "\r",
                  "                \"count\": {\r",
                  "                    \"type\": \"integer\",\r",
                  "                    \"minimum\": 0\r",
                  "                }\r",
                  "            }\r",
                  "        }\r",
                  "    }\r",
                  "};\r",
                  "\r",
                  "pm.test(\"Products array length is 20\", function () {\r",
                  "    pm.expect(products.length).to.eql(20);\r",
                  "});\r",
                  "\r",
                  "products.forEach(function (product) {\r",
                  "\r",
                  "    pm.test(\"Product \" + product.id + \" schema valid\", function () {\r",
                  "\r",
                  "        pm.expect(product).to.have.jsonSchema(productSchema);\r",
                  "\r",
                  "    });\r",
                  "\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "https://fakestoreapi.com/products",
              "protocol": "https",
              "host": [
                "fakestoreapi",
                "com"
              ],
              "path": [
                "products"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Request_Q",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();\r",
                  "\r",
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response is an array of length 4\", function () {\r",
                  "    pm.expect(json).to.be.an(\"array\");\r",
                  "    pm.expect(json.length).to.eql(4);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response contains all expected categories\", function () {\r",
                  "\r",
                  "    pm.expect(json).to.include.members([\r",
                  "        \"electronics\",\r",
                  "        \"jewelery\",\r",
                  "        \"men's clothing\",\r",
                  "        \"women's clothing\"\r",
                  "    ]);\r",
                  "\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "https://fakestoreapi.com/products/categories",
              "protocol": "https",
