            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Validate GET /api/users/2 response schema\", function () {\r",
                  "    const schema = {\r",
                  "        type: \"object\",\r",
                  "        required: [\"data\"],\r",
                  "        properties: {\r",
                  "            data: {\r",
                  "                type: \"object\",\r",
                  "                required: [\r",
                  "                    \"id\",\r",
                  "                    \"email\",\r",
                  "                    \"first_name\",\r",
                  "                    \"last_name\",\r",
                  "                    \"avatar\"\r",
                  "                ],\r",
                  "                properties: {\r",
                  "                    id: {\r",
                  "                        type: \"integer\"\r",
                  "                    },\r",
                  "                    email: {\r",
                  "                        type: \"string\",\r",
                  "                        pattern: \"^[\\\\w.-]+@[\\\\w.-]+\\\\.[A-Za-z]{2,}$\"\r",
                  "                    },\r",
                  "                    first_name: {\r",
                  "                        type: \"string\",\r",
                  "                        minLength: 1\r",
                  "                    },\r",
                  "                    last_name: {\r",
                  "                        type: \"string\",\r",
                  "                        minLength: 1\r",
                  "                    },\r",
                  "                    avatar: {\r",
                  "                        type: \"string\",\r",
                  "                        format: \"uri\"\r",
                  "                    }\r",
                  "                }\r",
                  "            }\r",
                  "        }\r",
                  "    };\r",
                  "\r",
                  "    pm.response.to.have.jsonSchema(schema);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Check mail\", function() {\r",
                  "    pm.expect(pm.response.json().data.email).to.match(/^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$/);\r",
                  "});"
                ],
