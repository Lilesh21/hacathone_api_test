        {
          "name": "Request C",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const jsonData = pm.response.json();\r",
                  "\r",
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"User details are correct\", function () {\r",
                  "    \r",
                  "    pm.expect(jsonData.data.email).to.eql(\"janet.weaver@reqres.in\");\r",
                  "    pm.expect(jsonData.data.first_name).to.eql(\"Janet\");\r",
                  "    pm.expect(jsonData.data.last_name).to.eql(\"Weaver\");\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const tokenExpiry = pm.environment.get(\"tokenExpiry\");\r",
                  "const now = Date.now();\r",
                  "\r",
                  "// Check whether token is missing or expired\r",
                  "if (!tokenExpiry || Number(tokenExpiry) < now) {\r",
                  "\r",
                  "    console.log(\"Token expired or missing — generating new token\");\r",
                  "\r",
                  "    pm.sendRequest({\r",
                  "        url: pm.environment.get(\"baseUrl\") + \"/api/login\",\r",
                  "        method: \"POST\",\r",
                  "        header: {\r",
                  "            \"Content-Type\": \"application/json\",\r",
                  "            \"x-api-key\": pm.environment.get(\"x-api-key\")\r",
                  "        },\r",
                  "        body: {\r",
                  "            mode: \"raw\",\r",
                  "            raw: JSON.stringify({\r",
                  "                email: \"eve.holt@reqres.in\",\r",
                  "                password: \"cityslicka\"\r",
                  "            })\r",
                  "        }\r",
                  "    }, function (err, res) {\r",
                  "\r",
                  "        if (err) {\r",
                  "            console.log(\"Error during login request:\", err);\r",
                  "            return;\r",
                  "        }\r",
                  "\r",
                  "        const responseJson = res.json();\r",
                  "\r",
                  "        // Save token in environment\r",
                  "        pm.environment.set(\"token\", responseJson.token);\r",
                  "\r",
                  "        // Save expiry time (1 hour from now)\r",
                  "        pm.environment.set(\r",
                  "            \"tokenExpiry\",\r",
                  "            Date.now() + 3600000\r",
                  "        );\r",
                  "\r",
                  "        console.log(\"New token saved successfully\");\r",
                  "    });\r",
                  "\r",
                  "} else {\r",
                  "\r",
                  "    console.log(\"Token valid — skipping refresh\");\r",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
